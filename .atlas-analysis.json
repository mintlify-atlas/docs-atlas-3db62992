    "mmdet.models.necks (FPN, PAFPN, etc.)",
    "mmdet.models.dense_heads (RetinaHead, FCOSHead, etc.)",
    "mmdet.models.roi_heads (StandardRoIHead, CascadeRoIHead, etc.)",
    "mmdet.models.losses (FocalLoss, GIoULoss, DiceLoss, etc.)",
